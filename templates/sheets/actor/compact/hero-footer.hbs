<footer class="compact-footer">
  {{#if isPlay}}
  <div class="compact-footer-row">

    <div class="compact-footer-group compact-footer-stamina">
      {{#if editable}}
      <button type="button" class="compact-footer-btn" data-action="spendStaminaHeroToken" data-tooltip="DRAW_STEEL.Setting.HeroTokens.RegainStamina.tooltip">{{systemFields.stamina.label}}</button>
      {{else}}
      <span class="compact-footer-label">{{systemFields.stamina.label}}</span>
      {{/if}}
      <span class="compact-stam-bar" style="--stam-current: {{system.stamina.value}}; --stam-max: {{system.stamina.max}};">
        <span class="compact-stam-fill"></span>
      </span>
      <input type="number" name="system.stamina.value" value="{{system.stamina.value}}">
      <span class="compact-footer-sep">/</span>
      <span class="compact-footer-static">{{system.stamina.max}}</span>
      <span class="compact-footer-sub">Temp</span>
      <input type="number" name="system.stamina.temporary" value="{{system.stamina.temporary}}">
    </div>

    <div class="compact-footer-group">
      {{#if editable}}
      <button type="button" class="compact-footer-btn" data-action="spendRecovery" data-tooltip="DRAW_STEEL.Actor.base.SpendRecovery.tooltip">{{systemFields.recoveries.label}}</button>
      {{else}}
      <span class="compact-footer-label">{{systemFields.recoveries.label}}</span>
      {{/if}}
      <input type="number" name="system.recoveries.value" value="{{system.recoveries.value}}">
      <span class="compact-footer-sep">/</span>
      <span class="compact-footer-static">{{system.recoveries.max}}</span>
      <span class="compact-footer-sub" data-tooltip-text="{{systemFields.recoveries.fields.recoveryValue.label}}">({{system.recoveries.recoveryValue}})</span>
    </div>

    <div class="compact-footer-group">
      {{#if editable}}
      <button type="button" class="compact-footer-btn" data-action="gainSurges" data-tooltip="DRAW_STEEL.Setting.HeroTokens.GainSurges.tooltip">{{systemFields.hero.fields.surges.label}}</button>
      {{else}}
      <span class="compact-footer-label">{{systemFields.hero.fields.surges.label}}</span>
      {{/if}}
      <input type="number" name="system.hero.surges" value="{{system.hero.surges}}">
    </div>

    <div class="compact-footer-group">
      <span class="compact-footer-label">{{system.hero.primary.label}}</span>
      <input type="number" name="system.hero.primary.value" value="{{system.hero.primary.value}}">
    </div>

  </div>
  {{else}}
  <div class="compact-footer-edit">
    <div class="compact-footer-group">
      <span class="compact-footer-label">{{systemFields.stamina.label}}</span>
      {{formInput systemFields.stamina.fields.max value=systemSource.stamina.max dataset=datasets.isSource}}
    </div>
    <div class="compact-footer-edit-section">
      {{> "systems/draw-steel/templates/sheets/actor/shared/partials/stats/combat.hbs"}}
      {{> "systems/draw-steel/templates/sheets/actor/shared/partials/stats/movement.hbs"}}
      {{> "systems/draw-steel/templates/sheets/actor/shared/partials/stats/immunities-weaknesses.hbs"}}
    </div>
    <div class="compact-footer-group compact-skills-edit">
      <span class="compact-footer-label">{{systemFields.skills.fields.value.label}}</span>
      {{formInput systemFields.skills.fields.value value=systemSource.skills.value options=skills.options dataset=datasets.isSource}}
    </div>
  </div>
  {{/if}}
</footer>
