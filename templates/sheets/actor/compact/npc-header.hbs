<header class="sheet-header compact-header">

  <img class="header-bg-art" src="modules/draw-steel-plus/assets/sketch-images/s2.jpg" aria-hidden="true">
  <div class="header-bg-overlay"></div>

  <div class="dsp-compact-art" aria-hidden="true">
    <img class="dsp-compact-art-image" src="{{document.img}}" alt="">
  </div>

  {{!-- Portrait control: view artwork in play, edit image out of play. --}}
  <a class="compact-art-action" data-action="{{ifThen isPlay "showPortraitArtwork" "editPortraitImage"}}"
    {{#unless isPlay}}data-edit="img"{{/unless}}
    data-tooltip="{{localize (ifThen isPlay "DRAW_STEEL_PLUS.Sheet.ViewArtwork" "DRAW_STEEL_PLUS.Sheet.EditImage")}}">
    <i class="fa-solid {{ifThen isPlay "fa-expand" "fa-pen"}}"></i>
  </a>

  {{!-- Two-column headline: left carries name / level-org-EV subline / keywords,
       right carries the role ribbon, tops aligned. --}}
  <div class="compact-headline-row">
    <div class="compact-headline-main">

      <div class="compact-title-row">
        {{#if isPlay}}
        <h1 class="char-name">{{document.name}}</h1>
        {{else}}
        {{formInput fields.name value=source.name placeholder=(localize "Name") class="char-name-input"}}
        {{/if}}
      </div>

      {{!-- Subline directly under the name, hero style: "LEVEL 2 · HORDE · EV 4" --}}
      <div class="compact-subline compact-progress-row">
        <span class="compact-stat"><b>{{systemFields.monster.fields.level.label}} {{system.monster.level}}</b></span>
        {{#if system.monster.organizationLabel}}
        <span class="compact-subline-sep">&middot;</span>
        <span class="compact-stat"><b>{{system.monster.organizationLabel}}</b></span>
        {{/if}}
        <span class="compact-subline-sep">&middot;</span>
        <span class="compact-stat">{{localize "DRAW_STEEL.Actor.base.EVLabel.Label"}} <b>{{system.evLabel}}</b></span>
        {{#unless isPlay}}
        <a data-action="editMonsterMetadata" class="compact-edit-meta" data-tooltip="DRAW_STEEL.Actor.npc.MonsterMetadata.DialogTitle">
          <i class="fa-solid fa-gear"></i>
        </a>
        {{/unless}}
      </div>

      {{#if monsterKeywords.length}}
      <div class="compact-meta-row compact-npc-meta">
        <span class="compact-keywords">{{#each monsterKeywords as |keyword|}}{{keyword}}{{#unless @last}}, {{/unless}}{{/each}}</span>
      </div>
      {{/if}}

      {{#if system.source.label}}
      <div class="compact-attribution">{{system.source.label}}</div>
      {{/if}}

    </div>

    {{!-- Right column: gradient ribbon carrying the role/organization. --}}
    <div class="compact-adornment">
      {{#if system.monster.roleLabel}}
      <div class="compact-ribbon" aria-hidden="true">{{system.monster.roleLabel}}</div>
      {{else if system.monster.organizationLabel}}
      <div class="compact-ribbon" aria-hidden="true">{{system.monster.organizationLabel}}</div>
      {{/if}}
    </div>
  </div>

  {{#if showMalice}}
  <div class="compact-malice-row">
    <span class="compact-label">{{malice.label}}</span>
    <input type="number" step="1" data-setting="malice" value="{{malice.value}}">
  </div>
  {{/if}}

  <div class="header-characteristics compact-characteristics">
    {{#each system.characteristics as |chr key|}}
    {{#if @root.isPlay}}
    <a
      class="char-badge {{disabled (not @root.owner)}}"
      data-action="roll"
      data-roll-type="characteristic"
      data-characteristic="{{key}}"
    >
      <span class="char-label">{{key}}</span>
      <span class="char-value">{{numberFormat chr.value sign=true}}</span>
    </a>
    {{else}}
    <label class="char-badge edit">
      <span class="char-label">{{key}}</span>
      <input type="number" name="system.characteristics.{{key}}.value" value="{{chr.value}}" placeholder="0">
    </label>
    {{/if}}
    {{/each}}
  </div>

  {{!-- COMBAT & MOVEMENT (left) + DEFENSES (right): two columns so defenses
       fills the dead space the skills column fills on hero. --}}
  <div class="compact-section compact-combat-skills">
    <div class="compact-col compact-combat">
      <div class="compact-section-label">Combat &amp; Movement</div>
      <div class="compact-run">
        <span class="compact-run-item"><span class="compact-run-k">Size</span><span class="compact-run-v">{{system.combat.size}}</span></span>
        <span class="compact-run-item"><span class="compact-run-k">{{movement.list}}</span><span class="compact-run-v">{{system.movement.value}}</span></span>
        <span class="compact-run-item"><span class="compact-run-k">Stability</span><span class="compact-run-v">{{system.combat.stability}}</span></span>
        <span class="compact-run-item"><span class="compact-run-k">Disengage</span><span class="compact-run-v">{{system.movement.disengage}}</span></span>
        <span class="compact-run-item"><span class="compact-run-k">{{systemFields.monster.fields.freeStrike.label}}</span><span class="compact-run-v">{{system.monster.freeStrike}}</span></span>
      </div>
    </div>

    <div class="compact-col compact-skills-section">
      <div class="compact-section-label">{{systemFields.damage.fields.immunities.label}} &amp; {{systemFields.damage.fields.weaknesses.label}}</div>
      <div class="compact-defwrap">
        <div class="compact-defline">
          <span class="compact-deftag">{{systemFields.damage.fields.immunities.label}}</span>
          {{#if damageIW.immunities}}<span class="compact-defvals">{{{damageIW.immunities}}}</span>{{else}}<span class="compact-none">None</span>{{/if}}
        </div>
        <div class="compact-defline">
          <span class="compact-deftag">{{systemFields.damage.fields.weaknesses.label}}</span>
          {{#if damageIW.weaknesses}}<span class="compact-defvals">{{{damageIW.weaknesses}}}</span>{{else}}<span class="compact-none">None</span>{{/if}}
        </div>
      </div>
    </div>
  </div>

</header>
