<li class="item ability draggable expandable-document compact-entry" data-document-uuid="{{ctx.item.uuid}}" data-ability-type="{{typeKey}}">
  <div class="compact-entry-head item-name">
    {{#if ctx.item.system.restricted}}
    <span class="restricted-warning" data-tooltip="DRAW_STEEL.Item.ability.Restricted">
      <i class="fa-solid fa-triangle-exclamation"></i>
    </span>
    {{/if}}
    <span class="label compact-entry-name" data-action="toggleDocumentDescription">{{ctx.item.name}}</span>
    <span class="compact-entry-meta">
      <span class="compact-dash">&mdash;</span> <span class="compact-type-label">{{typeLabel}}</span>{{#if ctx.formattedLabels.distance}} <span class="compact-pipe">|</span> {{ctx.formattedLabels.distance}}{{/if}}{{#if ctx.formattedLabels.target}} <span class="compact-pipe">|</span> {{ctx.formattedLabels.target}}{{/if}}{{#if (eq typeKey "villain")}} <span class="compact-pipe">|</span> {{localize "DRAW_STEEL.Item.ability.Order"}} {{ctx.order}}{{else}}{{#if ctx.item.system.resource}} <span class="compact-pipe">|</span> <span class="compact-resource-cost">{{ctx.item.system.resource}} {{@root.system.coreResource.name}}</span>{{/if}}{{/if}}
    </span>
    <span class="compact-entry-controls">
      <a class="fa-fw fa-solid fa-play" data-action="useAbility"></a>
      <a class="fa-fw fa-solid fa-comment" data-action="documentListShare"></a>
      {{#if @root.favoritesEnabled}}
      <a class="dsp-favorite-btn {{#if ctx.isFavorited}}dsp-favorited{{/if}}" data-action="toggleFavorite" data-tooltip="{{#if ctx.isFavorited}}DRAW_STEEL_PLUS.Favorites.Unfavorite{{else}}DRAW_STEEL_PLUS.Favorites.Favorite{{/if}}"><i class="fa-{{#if ctx.isFavorited}}solid{{else}}regular{{/if}} fa-star"></i></a>
      {{/if}}
      <a class="fa-fw fa-solid fa-ellipsis-vertical" data-action="documentListContext"></a>
      <a class="fa-fw fa-solid fa-angle-{{ifThen ctx.expanded "down" "right"}}" data-action="toggleDocumentDescription"></a>
    </span>
  </div>
  {{#if ctx.formattedLabels.keywords}}
  <div class="keywords compact-entry-keywords">{{ctx.formattedLabels.keywords}}</div>
  {{/if}}
  <div class="document-description item-embed content-embed {{#if ctx.expanded}}expanded{{/if}}">
    {{#if ctx.expanded}}{{{ctx.embed.outerHTML}}}{{/if}}
  </div>
</li>
