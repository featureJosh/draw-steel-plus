<section class="tab biography standard-form compact-bio {{tab.cssClass}}" data-group="primary" data-tab="biography">

  {{#if isPlay}}
  <div class="compact-run compact-bio-run">
    <span class="compact-run-item"><span class="compact-run-k">{{systemFields.hero.fields.renown.label}}</span><span class="compact-run-v">{{system.hero.renown}}</span></span>
    <span class="compact-run-item"><span class="compact-run-k">{{systemFields.hero.fields.wealth.label}}</span><span class="compact-run-v">{{system.hero.wealth}}</span></span>
    <span class="compact-run-item"><span class="compact-run-k">{{systemFields.biography.fields.age.label}}</span><span class="compact-run-v">{{system.biography.age}}</span></span>
    <span class="compact-run-item"><span class="compact-run-k">{{systemFields.biography.fields.height.label}}</span><span class="compact-run-v">{{system.biography.height.value}} {{measurements.heightUnit}}</span></span>
    <span class="compact-run-item"><span class="compact-run-k">{{systemFields.biography.fields.weight.label}}</span><span class="compact-run-v">{{system.biography.weight.value}} {{measurements.weightUnit}}</span></span>
  </div>
  {{else}}
  <div class="flexrow rewards">
    {{formGroup systemFields.hero.fields.renown value=systemSource.hero.renown dataset=datasets.isSource}}
    {{formGroup systemFields.hero.fields.wealth value=systemSource.hero.wealth dataset=datasets.isSource}}
  </div>
  <div class="flexrow appearance">
    {{formGroup systemFields.biography.fields.age value=systemSource.biography.age dataset=datasets.isSource}}
    <div class="form-group inline">
      <label>{{systemFields.biography.fields.height.label}}</label>
      <div class="form-fields">
        {{formInput systemFields.biography.fields.height.fields.value value=systemSource.biography.height.value dataset=datasets.isSource}}
        {{formInput systemFields.biography.fields.height.fields.units value=systemSource.biography.height.units dataset=datasets.isSource options=measurements.heightOptions}}
      </div>
    </div>
    <div class="form-group inline">
      <label>{{systemFields.biography.fields.weight.label}}</label>
      <div class="form-fields">
        {{formInput systemFields.biography.fields.weight.fields.value value=systemSource.biography.weight.value dataset=datasets.isSource}}
        {{formInput systemFields.biography.fields.weight.fields.units value=systemSource.biography.weight.units dataset=datasets.isSource options=measurements.weightOptions}}
      </div>
    </div>
  </div>
  {{/if}}

  {{> "systems/draw-steel/templates/sheets/actor/shared/partials/biography/languages.hbs"}}
  {{> "systems/draw-steel/templates/sheets/actor/shared/partials/biography/biography.hbs"}}
  {{> "systems/draw-steel/templates/sheets/actor/shared/partials/biography/director-notes.hbs"}}
</section>
