
{{#*inline "headerTag"}}
{{#if originDoc}}
<span class="tag-content" data-document-uuid="{{lookup originDoc "uuid"}}">
  <a class="filled" data-action="viewDoc">
    {{lookup originDoc "name"}}
  </a>
  {{#unless (or @root.isPlay noEdit)}}
  <a data-action="deleteDoc" class="delete-icon">
    <i class="fa-solid fa-trash-can"></i>
  </a>
  {{/unless}}
</span>
{{else}}
{{#if @root.isPlay}}
<span class="unfilled">
  {{localize "DRAW_STEEL.SHEET.NoDocument" documentName=(localize (concat "TYPES.Item." originType))}}
</span>
{{else}}
{{#unless noEdit}}
<a class="unfilled add-icon" data-action="addOrigin" data-type="{{originType}}">
  {{localize "DRAW_STEEL.SHEET.Add" itemName=(localize (concat "TYPES.Item." originType))}}
</a>
{{/unless}}
{{/if}}
{{/if}}
{{/inline}}

<header class="sheet-header compact-header">

  <img class="header-bg-art" src="modules/draw-steel-plus/assets/sketch-images/s1.jpg" aria-hidden="true">
  <div class="header-bg-overlay"></div>

  <div class="dsp-compact-art" aria-hidden="true">
    <img class="dsp-compact-art-image" src="{{document.img}}" alt="">
  </div>

  {{!-- Portrait control: view artwork in play, edit image out of play (the art
       itself is decorative/pointer-events:none, so parity needs this affordance). --}}
  <a class="compact-art-action" data-action="{{ifThen isPlay "showPortraitArtwork" "editPortraitImage"}}"
    {{#unless isPlay}}data-edit="img"{{/unless}}
    data-tooltip="{{localize (ifThen isPlay "DRAW_STEEL_PLUS.Sheet.ViewArtwork" "DRAW_STEEL_PLUS.Sheet.EditImage")}}">
    <i class="fa-solid {{ifThen isPlay "fa-expand" "fa-pen"}}"></i>
  </a>

  {{!-- Two-column headline: left carries name / progress / origin tags, right
       carries the class ribbon, tops aligned. --}}
  <div class="compact-headline-row">
    <div class="compact-headline-main">

      <div class="compact-title-row">
        {{#if isPlay}}
        <h1 class="char-name">{{document.name}}</h1>
        {{else}}
        {{formInput fields.name value=source.name placeholder=(localize "Name") class="char-name-input"}}
        {{/if}}
      </div>

      {{!-- Subline directly under the name, reference-style: "LEVEL 1 · 5 XP · 0 VICTORIES" --}}
      <div class="compact-subline compact-progress-row {{#unless isPlay}}progression-edit{{/unless}}">
        {{#if system.advancementReady}}
        <a class="compact-stat" data-action="levelUp" data-tooltip="DRAW_STEEL.SHEET.LevelUp"><b>{{localize "DRAW_STEEL.Item.class.FIELDS.level.label"}} {{system.level}}</b></a>
        {{else}}
        <span class="compact-stat"><b>{{localize "DRAW_STEEL.Item.class.FIELDS.level.label"}} {{system.level}}</b></span>
        {{/if}}
        {{#if isPlay}}
        <span class="compact-subline-sep">&middot;</span>
        <span class="compact-stat"><b>{{system.hero.xp}}</b>{{#if system.nextLevelXP}}<span class="compact-stat-max"> / {{system.nextLevelXP}}</span>{{/if}} XP</span>
        <span class="compact-subline-sep">&middot;</span>
        <span class="compact-stat"><b>{{system.hero.victories}}</b>{{#if system.victoriesMax}}<span class="compact-stat-max"> / {{system.victoriesMax}}</span>{{/if}} Victories</span>
        <a class="compact-respite" data-action="takeRespite" data-tooltip="DRAW_STEEL.Actor.hero.TakeRespite">
          <i class="fa-solid fa-bed"></i>
        </a>
        {{else}}
        {{formGroup systemFields.hero.fields.xp value=systemSource.hero.xp classes="xp-edit"}}
        {{formGroup systemFields.hero.fields.victories value=systemSource.hero.victories classes="victories-edit"}}
        {{/if}}
      </div>

      <div class="origins-row compact-meta-row">
        <div class="ancestry tag">
          {{> headerTag originDoc=document.system.ancestry originType="ancestry"}}
        </div>
        <div class="culture tag">
          {{> headerTag originDoc=document.system.culture originType="culture"}}
        </div>
        <div class="career tag">
          {{> headerTag originDoc=document.system.career originType="career"}}
        </div>
        <div class="class tag">
          {{> headerTag originDoc=document.system.class originType="class"}}
        </div>
        {{#each document.system.subclasses as |subclass|}}
        <div class="subclass tag">
          {{> headerTag originDoc=subclass originType="subclass" noEdit=true}}
        </div>
        {{/each}}
      </div>

    </div>

    {{!-- Right column: gradient ribbon carrying the class. --}}
    <div class="compact-adornment">
      <div class="compact-ribbon" aria-hidden="true">{{#if document.system.class}}{{document.system.class.name}}{{else}}{{localize "TYPES.Actor.hero"}}{{/if}}</div>
    </div>
  </div>

  <div class="header-characteristics compact-characteristics">
    {{#unless isPlay}}
    <button type="button" class="char-edit-btn fa-solid fa-cog" data-action="editCharacteristics"></button>
    {{/unless}}
    {{#each system.characteristics as |chr key|}}
    <a
      class="char-badge {{disabled (not @root.owner)}}"
      data-action="roll"
      data-roll-type="characteristic"
      data-characteristic="{{key}}"
      {{disabled (not @root.isPlay)}}
    >
      <span class="char-label">{{key}}</span>
      <span class="char-value">{{numberFormat chr.value sign=true}}</span>
    </a>
    {{/each}}
  </div>

  {{!-- Vitals (stamina / recoveries / surges / heroic resource) live in the
       always-visible compact footer strip, reference style. --}}

  {{!-- COMBAT & MOVEMENT (left) + SKILLS (right): two columns so skills fills the
       dead space beside the short combat run instead of overflowing below. --}}
  <div class="compact-section compact-combat-skills">
    <div class="compact-col compact-combat">
      <div class="compact-section-label">Combat &amp; Movement</div>
      <div class="compact-run">
        <span class="compact-run-item"><span class="compact-run-k">Size</span><span class="compact-run-v">{{system.combat.size}}</span></span>
        <span class="compact-run-item"><span class="compact-run-k">{{movement.list}}</span><span class="compact-run-v">{{system.movement.value}}</span></span>
        <span class="compact-run-item"><span class="compact-run-k">Stability</span><span class="compact-run-v">{{system.combat.stability}}</span></span>
        <span class="compact-run-item"><span class="compact-run-k">Disengage</span><span class="compact-run-v">{{system.movement.disengage}}</span></span>
      </div>
      <div class="compact-defwrap">
        <div class="compact-defline">
          <span class="compact-deftag">{{systemFields.damage.fields.immunities.label}}</span>
          {{#if damageIW.immunities}}<span class="compact-defvals">{{{damageIW.immunities}}}</span>{{else}}<span class="compact-none">None</span>{{/if}}
        </div>
        <div class="compact-defline">
          <span class="compact-deftag">{{systemFields.damage.fields.weaknesses.label}}</span>
          {{#if damageIW.weaknesses}}<span class="compact-defvals">{{{damageIW.weaknesses}}}</span>{{else}}<span class="compact-none">None</span>{{/if}}
        </div>
      </div>
    </div>

    <div class="compact-col compact-skills-section">
      <div class="compact-section-label">
        {{systemFields.skills.fields.value.label}}
        {{#if unfilledSkill}}
        <button type="button" class="icon fa-solid fa-clipboard-question compact-fill-trait" data-tooltip-text="{{localize "DRAW_STEEL.ADVANCEMENT.FillTrait.button" type=(localize "TYPES.Advancement.skill")}}" data-tooltip-direction="UP" data-action="fillTrait" data-type="skill"></button>
        {{/if}}
      </div>
      {{#if skills.list}}<div class="compact-skills-line">{{skills.list}}</div>{{else}}<div class="compact-none">None</div>{{/if}}
    </div>
  </div>

</header>
